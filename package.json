{
  "name": "pinia-mini-plugin-persistor",
  "version": "1.0.0",
  "type": "module",
  "description": "Persistence plugin for @vue-mini/pinia",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm-bundler.js",
  "types": "dist/index.d.ts",
  "repository": "https://github.com/yangmingshan/pinia-mini-plugin-persistor.git",
  "author": "Yang Mingshan <y.mingshan3@gmail.com>",
  "license": "MIT",
  "scripts": {
    "format": "prettier --check \"**/*.{js,ts,json,md}\"",
    "lint": "eslint .",
    "type": "tsc --noEmit",
    "test": "vitest",
    "build": "node build.ts",
    "prepare": "husky"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm-bundler.js",
      "require": "./dist/index.cjs.js",
      "default": "./dist/index.cjs.js"
    },
    "./package.json": "./package.json"
  },
  "keywords": [
    "persistence",
    "pinia",
    "vue",
    "mini",
    "vue-mini",
    "wechat",
    "weixin",
    "miniprogram",
    "mp",
    "微信",
    "小程序"
  ],
  "peerDependencies": {
    "@vue-mini/core": "^1.2.5",
    "@vue-mini/pinia": "^1.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "rollup": "^4.62.2",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
